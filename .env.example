# FlipScout — environment variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# ── Required: Telegram ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Optional: Discord ─────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# ── Optional: Sniper sessions ─────────────────────────────────────────────────
# Wallapop: get Bearer token from DevTools > Network > any API request > Authorization header
WALLAPOP_AUTH_TOKEN=

# Vinted: get from DevTools > Application > Cookies > _vinted_fr_session
VINTED_SESSION_COOKIE=

# ── Optional: eBay Finding API ────────────────────────────────────────────────
# Register at developer.ebay.com (free) to get an App ID
EBAY_APP_ID=

# ── Optional: Dashboard API port (default: 8000) ──────────────────────────────
API_PORT=8000

# ── Optional: Sniper safety limits ───────────────────────────────────────────
SNIPER_MAX_DAILY_SPEND_EUR=500
# Set to 1 to pause all sniper polling on startup
SNIPER_PAUSED=0
